[Unit]
Description=Lantransfer File Transfer Server
After=network.target

[Service]
Type=simple
User=root
# Replace /path/to/Lantransfer with the actual path
WorkingDirectory=/path/to/Lantransfer
ExecStart=/path/to/Lantransfer/lantransfer
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
