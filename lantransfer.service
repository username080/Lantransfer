[Unit]
Description=Lantransfer File Transfer Server
After=network.target

[Service]
Type=simple
User=root
# Replace /path/to/lantransfer with the actual absolute path to your lantransfer folder
WorkingDirectory=/path/to/lantransfer
ExecStart=/path/to/lantransfer/lantransfer
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
